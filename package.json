{
  "name": "globaltracker",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "typecheck": "pnpm -r run --if-present typecheck",
    "lint": "biome check .",
    "test": "vitest run",
    "build": "pnpm -r run build",
    "deploy:edge": "set -a && . ./.env.local && set +a && cd apps/edge && npx wrangler@4 deploy"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "hono": "^4.0.0",
    "postgres": "^3.4.9",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
